{
  "expo": {
    "name": "Studynk",
    "slug": "studynk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "studymatch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studymatch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take a profile photo for your account",
        "NSPhotoLibraryUsageDescription": "Choose a profile photo from your library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#2DAFE3"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.studymatch.app",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png",
      "name": "Studynk",
      "shortName": "Studynk",
      "description": "The Verified Way to Find Your Study Squad"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2DAFE3"
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a profile photo from your library",
          "cameraPermission": "Take a profile photo for your account"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
